# Copy to .env and adjust. Never commit real secrets.

# --- Local Postgres (docker compose --profile local-db up) ---
POSTGRES_DB=reimbursement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# --- Neon PostgreSQL (Cloud Run / remote) ---
# Format: jdbc:postgresql://ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# SPRING_DATASOURCE_USERNAME=neondb_owner
# SPRING_DATASOURCE_PASSWORD=your-neon-password
# SPRING_JPA_DEFAULT_SCHEMA=public

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/reimbursement
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_DEFAULT_SCHEMA=public
SPRING_JPA_HIBERNATE_DDL_AUTO=update

BACKEND_PORT=8080
FRONTEND_PORT=8081
ERS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
ERS_API_SERVER_URL=http://localhost:8080
REACT_APP_API_BASE_URL=http://localhost:8080

ERS_VENDOR_PROVIDER=mock-sap
SERVER_SERVLET_SESSION_COOKIE_SECURE=false
SERVER_SERVLET_SESSION_COOKIE_SAME_SITE=lax

# --- Google Cloud Run (set as GitHub Actions secrets; do not put here) ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# GCP_SA_KEY=
# NEON_JDBC_URL=
# NEON_DB_USER=
# NEON_DB_PASSWORD=
# FRONTEND_ORIGIN=https://your-frontend.example.com
